@page "/coffee"
@page "/fr/coffee"
@page "/vi/coffee"
@page "/ru/coffee"
@layout Layout.CoffeeLayout
@inject LocalizationService L
@inject NavigationManager Nav

<PageTitle>@L["cof.meta.title"]</PageTitle>

<NavBar ShowCta="false" />

<main class="lp">

    <!-- ===================== HERO ===================== -->
    <section class="lp-hero" id="top">
        <div class="container lp-hero__grid">
            <div class="lp-hero__content">
                <span class="eyebrow">@L["cof.hero.eyebrow"]</span>
                <h1 class="lp-hero__title">@L["cof.hero.title.a"] <span>@L["cof.hero.title.b"]</span></h1>
                <p class="lp-hero__sub">@L["cof.hero.sub"]</p>
                <div class="lp-hero__ctas">
                    <a class="btn btn-primary" href="https://coffee.maplekiosk.ca" target="_blank" rel="noopener">@L["cof.cta.trial"]</a>
                    <a class="btn btn-ghost" href="#floor">@L["cof.hero.cta2"]</a>
                </div>
                <p class="lp-hero__note">@L["cof.hero.note"] · English · Français · Tiếng Việt · Русский</p>
            </div>
            <div class="lp-hero__media">
                <img src="https://images.unsplash.com/photo-1558857563-b371033873b8?w=800&q=80"
                     alt="" loading="lazy" data-fallback="Boba tea & coffee" />
                <div class="lp-hero__chip lp-hero__chip--a">@L["cof.hero.chip.a"]</div>
                <div class="lp-hero__chip lp-hero__chip--b">@L["cof.hero.chip.b"]</div>
            </div>
        </div>
    </section>

    <!-- ===================== FLUENCY BAND ===================== -->
    <section class="section section--surface fade-in">
        <div class="container">
            <div class="lp-band__head">
                <span class="eyebrow">@L["cof.band1.eyebrow"]</span>
                <h2>@L["cof.band1.title"]</h2>
                <p>@L["cof.band1.desc"]</p>
            </div>
            <div class="lp-fluency">
                <div class="lp-fluency__item">
                    <span class="lp-fluency__q">@L["cof.fluency.1.q"]</span>
                    <p>@L["cof.fluency.1.d"]</p>
                </div>
                <div class="lp-fluency__item">
                    <span class="lp-fluency__q">@L["cof.fluency.2.q"]</span>
                    <p>@L["cof.fluency.2.d"]</p>
                </div>
                <div class="lp-fluency__item">
                    <span class="lp-fluency__q">@L["cof.fluency.3.q"]</span>
                    <p>@L["cof.fluency.3.d"]</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ===================== CAPABILITY GRID ===================== -->
    <section class="section fade-in">
        <div class="container">
            <div class="features__head">
                <div>
                    <span class="eyebrow">@L["cof.grid.eyebrow"]</span>
                    <h2>@L["cof.grid.title"]</h2>
                </div>
                <p>@L["cof.grid.desc"]</p>
            </div>

            <div class="features__grid">
                <div class="feature">
                    <div class="feature__icon">⚡</div>
                    <h3>@L["cof.cap.1.title"]</h3>
                    <p>@L["cof.cap.1.desc"]</p>
                </div>
                <div class="feature feature--featured">
                    <span class="feature__flag">@L["cof.cap.2.flag"]</span>
                    <div class="feature__icon">🧋</div>
                    <h3>@L["cof.cap.2.title"]</h3>
                    <p>@L["cof.cap.2.desc"]</p>
                </div>
                <div class="feature">
                    <div class="feature__icon">🖥️</div>
                    <h3>@L["cof.cap.3.title"]</h3>
                    <p>@L["cof.cap.3.desc"]</p>
                </div>
                <div class="feature">
                    <div class="feature__icon">📱</div>
                    <h3>@L["cof.cap.4.title"]</h3>
                    <p>@L["cof.cap.4.desc"]</p>
                </div>
                <div class="feature">
                    <div class="feature__icon">🍔</div>
                    <h3>@L["cof.cap.5.title"]</h3>
                    <p>@L["cof.cap.5.desc"]</p>
                </div>
                <div class="feature">
                    <div class="feature__icon">📦</div>
                    <h3>@L["cof.cap.6.title"]</h3>
                    <p>@L["cof.cap.6.desc"]</p>
                </div>
                <div class="feature">
                    <div class="feature__icon">🎁</div>
                    <h3>@L["cof.cap.7.title"]</h3>
                    <p>@L["cof.cap.7.desc"]</p>
                </div>
                <div class="feature">
                    <div class="feature__icon">🚚</div>
                    <h3>@L["cof.cap.8.title"]</h3>
                    <p>@L["cof.cap.8.desc"]</p>
                </div>
                <div class="feature">
                    <div class="feature__icon">🤖</div>
                    <h3>@L["cof.cap.9.title"]</h3>
                    <p>@L["cof.cap.9.desc"]</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ===================== A MORNING AT THE COUNTER ===================== -->
    <section class="section section--surface fade-in" id="floor">
        <div class="container">
            <div class="lp-band__head lp-band__head--center">
                <span class="eyebrow">@L["cof.floor.eyebrow"]</span>
                <h2>@L["cof.floor.title"]</h2>
                <p>@L["cof.floor.desc"]</p>
            </div>

            <ol class="lp-timeline">
                <li class="lp-step">
                    <span class="lp-step__time">7:00</span>
                    <div class="lp-step__body">
                        <h3>@L["cof.step.1.t"]</h3>
                        <p>@L["cof.step.1.d"]</p>
                    </div>
                </li>
                <li class="lp-step">
                    <span class="lp-step__time">8:15</span>
                    <div class="lp-step__body">
                        <h3>@L["cof.step.2.t"]</h3>
                        <p>@L["cof.step.2.d"]</p>
                    </div>
                </li>
                <li class="lp-step">
                    <span class="lp-step__time">11:30</span>
                    <div class="lp-step__body">
                        <h3>@L["cof.step.3.t"]</h3>
                        <p>@L["cof.step.3.d"]</p>
                    </div>
                </li>
                <li class="lp-step">
                    <span class="lp-step__time">2:00</span>
                    <div class="lp-step__body">
                        <h3>@L["cof.step.4.t"]</h3>
                        <p>@L["cof.step.4.d"]</p>
                    </div>
                </li>
                <li class="lp-step">
                    <span class="lp-step__time">8:00</span>
                    <div class="lp-step__body">
                        <h3>@L["cof.step.5.t"]</h3>
                        <p>@L["cof.step.5.d"]</p>
                    </div>
                </li>
            </ol>
        </div>
    </section>

    <!-- ===================== DEEP DIVE: THE DRINK TICKET ===================== -->
    <section class="section fade-in">
        <div class="container lp-split">
            <div class="lp-split__text">
                <span class="eyebrow">@L["cof.pay.eyebrow"]</span>
                <h2>@L["cof.pay.title"]</h2>
                <p>@L["cof.pay.desc"]</p>
                <ul class="lp-checks">
                    <li>@L["cof.pay.check.1"]</li>
                    <li>@L["cof.pay.check.2"]</li>
                    <li>@L["cof.pay.check.3"]</li>
                    <li>@L["cof.pay.check.4"]</li>
                    <li>@L["cof.pay.check.5"]</li>
                </ul>
            </div>
            <aside class="lp-payout" aria-label="@L["cof.pay.card.aria"]">
                <div class="lp-payout__head">
                    <span>@L["cof.pay.card.head"]</span>
                    <span class="lp-payout__tag">@L["cof.pay.card.tag"]</span>
                </div>
                <dl class="lp-payout__rows">
                    <div><dt>@L["cof.pay.row.1"]</dt><dd>$5.50</dd></div>
                    <div><dt>@L["cof.pay.row.2"]</dt><dd>incl.</dd></div>
                    <div><dt>@L["cof.pay.row.3"]</dt><dd>+$0.75</dd></div>
                    <div><dt>@L["cof.pay.row.4"]</dt><dd>+$0.75</dd></div>
                    <div><dt>@L["cof.pay.row.5"]</dt><dd>+$0.50</dd></div>
                    <div class="lp-payout__total"><dt>@L["cof.pay.row.total"]</dt><dd>$7.50</dd></div>
                </dl>
                <p class="lp-payout__foot">@L["cof.pay.card.foot"]</p>
            </aside>
        </div>
    </section>

    <!-- ===================== AI CALLOUT ===================== -->
    <section class="section section--surface fade-in">
        <div class="container lp-split lp-split--reverse">
            <div class="lp-split__text">
                <span class="eyebrow">@L["cof.ai.eyebrow"]</span>
                <h2>@L["cof.ai.title"]</h2>
                <p>@L["cof.ai.desc"]</p>
                <ul class="lp-checks">
                    <li>@L["cof.ai.check.1"]</li>
                    <li>@L["cof.ai.check.2"]</li>
                    <li>@L["cof.ai.check.3"]</li>
                    <li>@L["cof.ai.check.4"]</li>
                    <li>@L["cof.ai.check.5"]</li>
                </ul>
                <a class="btn btn-primary" href="https://coffee.maplekiosk.ca" target="_blank" rel="noopener">@L["cof.cta.trial"]</a>
            </div>
            <div class="lp-split__media">
                <img src="https://images.unsplash.com/photo-1521017432531-fbd92d768814?w=800&q=80"
                     alt="" loading="lazy" data-fallback="Café counter" />
            </div>
        </div>
    </section>

    <!-- ===================== CTA ===================== -->
    <section class="section fade-in">
        <div class="container lp-cta">
            <span class="eyebrow">@L["cof.cta.eyebrow"]</span>
            <h2>@L["cof.cta.title"]</h2>
            <p>@L["cof.cta.desc"]</p>
            <div class="lp-cta__actions">
                <a class="btn btn-primary" href="https://coffee.maplekiosk.ca" target="_blank" rel="noopener">@L["cof.cta.trial"]</a>
                <a class="btn btn-ghost" href="/#pricing">@L["cof.cta.pricing"]</a>
            </div>
        </div>
    </section>

</main>

<Footer />

@code {
    protected override void OnInitialized()
    {
        // Localized routes: /coffee (en), /fr/coffee, /vi/coffee, /ru/coffee.
        var seg = new Uri(Nav.Uri).AbsolutePath.Trim('/').Split('/').FirstOrDefault() ?? "";
        L.SetCulture(seg);
    }
}
