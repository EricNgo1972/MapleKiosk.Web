@inherits LayoutComponentBase

@*
    Dedicated layout for the MapleCoffee (/coffee) sub-brand page.
    Like NailsLayout, it is intentionally NOT shared with the main app
    (Layout.MainLayout): own shell, no ShopWidget, so the industry pages stay
    independent of each other and of the marketing site.
*@

<div class="bg-fx" aria-hidden="true">
    <div class="bg-fx__blob bg-fx__blob--a"></div>
    <div class="bg-fx__blob bg-fx__blob--b"></div>
    <div class="bg-fx__blob bg-fx__blob--c"></div>
</div>

@Body

<div id="blazor-error-ui" style="display:none;">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>
