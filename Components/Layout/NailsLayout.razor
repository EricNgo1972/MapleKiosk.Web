@inherits LayoutComponentBase

@*
    Dedicated layout for the MapleSpa (/nails) sub-brand page.
    Intentionally NOT shared with the main app (Layout.MainLayout): it keeps its
    own shell so changes to either layout never leak into the other, and it omits
    the main app's ShopWidget. Keeps its own background atmosphere and error UI.
*@

<div class="bg-fx" aria-hidden="true">
    <div class="bg-fx__blob bg-fx__blob--a"></div>
    <div class="bg-fx__blob bg-fx__blob--b"></div>
    <div class="bg-fx__blob bg-fx__blob--c"></div>
</div>

@Body

<div id="blazor-error-ui" style="display:none;">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>
