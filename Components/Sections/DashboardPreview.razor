@inject LocalizationService L

<section class="section section--surface dashboard fade-in">
    <div class="container">
        <span class="eyebrow">@L["dash.eyebrow"]</span>
        <h2>@L["dash.title"]</h2>
        <p>@L["dash.desc"]</p>
        <div class="browser">
            <div class="browser__bar">
                <i></i><i></i><i></i>
                <span>app.maplekiosk.com / dashboard</span>
            </div>
            <img src="https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=1200&q=80"
                 alt="" loading="lazy" data-fallback="Dashboard preview" />
        </div>
        <a class="btn btn-primary" href="javascript:void(0)" data-open-trial>@L["dash.cta"]</a>
    </div>
</section>
