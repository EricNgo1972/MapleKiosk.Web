@inject LocalizationService L

<section class="logo-strip fade-in">
    <div class="container">
        <div class="logo-strip__label">@L["strip.label"]</div>
        <div class="logo-strip__badges">
            <span class="badge">@L["strip.nail"]</span>
            <span class="badge">@L["strip.resto"]</span>
            <span class="badge">@L["strip.garage"]</span>
            <span class="badge">@L["strip.retail"]</span>
            <span class="badge">@L["strip.startup"]</span>
        </div>
    </div>
</section>
