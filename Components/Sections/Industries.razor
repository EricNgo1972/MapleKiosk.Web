@inject LocalizationService L

<section class="section fade-in" id="industries">
    <div class="container industries__grid">
        <div>
            <span class="eyebrow">@L["ind.eyebrow"]</span>
            <h2>@L["ind.title"]</h2>
            <ul class="industries__list">
                <li><span class="ico">💅</span> @L["ind.nail"]</li>
                <li><span class="ico">🍔</span> @L["ind.resto"]</li>
                <li><span class="ico">🛍</span> @L["ind.retail"]</li>
                <li><span class="ico">🔧</span> @L["ind.garage"]</li>
                <li><span class="ico">🚀</span> @L["ind.startup"]</li>
            </ul>
        </div>
        <div class="industries__collage">
            <div class="ph ph--tall">
                <img src="https://images.unsplash.com/photo-1604654894610-df63bc536371?w=600&q=80"
                     alt="" loading="lazy" data-fallback="Nail Salon" />
            </div>
            <div class="ph">
                <img src="https://images.unsplash.com/photo-1414235077428-338989a2e8c0?w=600&q=80"
                     alt="" loading="lazy" data-fallback="Restaurant" />
            </div>
            <div class="ph">
                <img src="https://images.unsplash.com/photo-1441986300917-64674bd600d8?w=600&q=80"
                     alt="" loading="lazy" data-fallback="Retail" />
            </div>
        </div>
    </div>
</section>
