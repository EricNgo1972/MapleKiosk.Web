@inject LocalizationService L

<footer class="footer">
    <div class="container">
        <div class="footer__top">
            <div class="footer__brand">
                <div class="footer__logo"><img src="MapleKiosk_rectangle.png" alt="MapleKiosk" /></div>
                <p>@L["foot.brand"]</p>
            </div>
            <div class="footer__col">
                <h5>@L["foot.product"]</h5>
                <ul>
                    <li><a href="#features">@L["nav.features"]</a></li>
                    <li><a href="#pricing">@L["nav.pricing"]</a></li>
                    <li><a href="#how">@L["nav.how"]</a></li>
                    <li><a href="#">@L["foot.integ"]</a></li>
                </ul>
            </div>
            <div class="footer__col">
                <h5>@L["foot.industries"]</h5>
                <ul>
                    <li><a href="#industries">@L["ind.nail"]</a></li>
                    <li><a href="#industries">@L["ind.resto"]</a></li>
                    <li><a href="#industries">@L["ind.retail"]</a></li>
                    <li><a href="#industries">@L["ind.garage"]</a></li>
                </ul>
            </div>
            <div class="footer__col">
                <h5>@L["foot.company"]</h5>
                <ul>
                    <li><a href="#">@L["foot.about"]</a></li>
                    <li><a href="#">@L["foot.blog"]</a></li>
                    <li><a href="#">@L["foot.careers"]</a></li>
                    <li><a href="#">@L["foot.contact"]</a></li>
                </ul>
            </div>
            <div class="footer__col">
                <h5>@L["foot.legal"]</h5>
                <ul>
                    <li><a href="@LegalPath("privacy")">@L["foot.privacy"]</a></li>
                    <li><a href="@LegalPath("terms")">@L["foot.terms"]</a></li>
                    <li><a href="#">@L["foot.security"]</a></li>
                    <li><a href="#">@L["foot.cookies"]</a></li>
                </ul>
            </div>
        </div>
        <div class="footer__bottom">
            <span>© @DateTime.Now.Year MapleKiosk Inc. @L["foot.rights"]</span>
            <span>@L["foot.made"]</span>
        </div>
    </div>
</footer>

@code {
    private string LegalPath(string page)
    {
        var root = L.Path(L.Culture).TrimEnd('/');
        return string.IsNullOrEmpty(root) ? $"/{page}" : $"{root}/{page}";
    }
}
