<section class="section section--surface fade-in" id="features">
    <div class="container">
        <div class="features__head">
            <div>
                <span class="eyebrow">Features</span>
                <h2>Every tool your business actually needs.</h2>
            </div>
            <p>From the first customer to the thousandth transaction, MapleKiosk replaces a drawer full of apps with one calm, cohesive system.</p>
        </div>
        <div class="features__grid">
            @foreach (var f in _features)
            {
                <div class="feature">
                    <span class="feature__num">@f.Num</span>
                    <div class="feature__icon">@f.Icon</div>
                    <h3>@f.Title</h3>
                    <p>@f.Desc</p>
                </div>
            }
        </div>
    </div>
</section>

@code {
    private record F(string Num, string Icon, string Title, string Desc);
    private readonly F[] _features = new[]
    {
        new F("01","🛒","Smart Point of Sale","Fast, flexible checkout that runs on any device — cash, card, tap or QR."),
        new F("02","📅","Appointment & Booking","Online booking, reminders and no-show protection baked in."),
        new F("03","📊","Analytics Dashboard","Real-time revenue, staff and product insights at a glance."),
        new F("04","👥","Staff Management","Shifts, commissions, permissions and payroll exports handled."),
        new F("05","🎁","Loyalty & Promotions","Built-in gift cards, points, referrals and campaigns."),
        new F("06","📱","Multi-device Access","Seamless sync across iPad, phone, desktop and kiosk terminals."),
    };
}
