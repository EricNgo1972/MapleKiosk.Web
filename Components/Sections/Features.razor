@inject LocalizationService L

<section class="section section--surface fade-in" id="features">
    <div class="container">
        <div class="features__head">
            <div>
                <span class="eyebrow">@L["features.eyebrow"]</span>
                <h2>@L["features.title"]</h2>
            </div>
            <p>@L["features.desc"]</p>
        </div>
        <div class="features__grid">
            @foreach (var (num, icon, keyPrefix) in _features)
            {
                <div class="feature">
                    <span class="feature__num">@num</span>
                    <div class="feature__icon">@icon</div>
                    <h3>@L[$"{keyPrefix}.title"]</h3>
                    <p>@L[$"{keyPrefix}.desc"]</p>
                </div>
            }
        </div>
    </div>
</section>

@code {
    private readonly (string num, string icon, string prefix)[] _features = new[]
    {
        ("01","🛒","features.01"),
        ("02","📅","features.02"),
        ("03","📊","features.03"),
        ("04","👥","features.04"),
        ("05","🎁","features.05"),
        ("06","📱","features.06"),
    };
}
