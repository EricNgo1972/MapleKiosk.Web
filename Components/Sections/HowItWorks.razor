@inject LocalizationService L

<section class="section section--surface fade-in" id="how">
    <div class="container" style="text-align:center">
        <span class="eyebrow">@L["how.eyebrow"]</span>
        <h2 style="font-size:clamp(32px,4vw,52px);margin-top:16px">@L["how.title"]</h2>
        <div class="steps">
            <div class="step"><div class="step__num">I</div><h4>@L["how.s1.t"]</h4><p>@L["how.s1.d"]</p></div>
            <div class="step"><div class="step__num">II</div><h4>@L["how.s2.t"]</h4><p>@L["how.s2.d"]</p></div>
            <div class="step"><div class="step__num">III</div><h4>@L["how.s3.t"]</h4><p>@L["how.s3.d"]</p></div>
            <div class="step"><div class="step__num">IV</div><h4>@L["how.s4.t"]</h4><p>@L["how.s4.d"]</p></div>
        </div>
    </div>
</section>
