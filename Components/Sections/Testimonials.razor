@inject LocalizationService L

<section class="section fade-in">
    <div class="container">
        <span class="eyebrow">@L["test.eyebrow"]</span>
        <h2 style="font-size:clamp(32px,4vw,52px);margin-top:16px;max-width:640px">@L["test.title"]</h2>
        <div class="testimonials__grid">
            @foreach (var t in _items)
            {
                <div class="tcard">
                    <span class="tcard__quote">&ldquo;</span>
                    <div class="stars">★★★★★</div>
                    <p class="tcard__text">@L[t.QuoteKey]</p>
                    <div class="tcard__author">
                        <div class="avatar">@t.Initials</div>
                        <div>
                            <span class="tcard__name">@t.Name</span>
                            <span class="tcard__biz">@t.Biz</span>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

@code {
    private record T(string Initials, string Name, string Biz, string QuoteKey);
    private readonly T[] _items = new[]
    {
        new T("SL","Sophie Leblanc","Nails & Co. — Montreal","test.q1"),
        new T("MC","Marc Charbonneau","Pro Auto Service — Laval","test.q2"),
        new T("AK","Anika Kapoor","The Spice Route — Ottawa","test.q3"),
    };
}
