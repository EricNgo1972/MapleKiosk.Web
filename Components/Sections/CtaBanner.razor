@inject LocalizationService L

<section class="cta-banner fade-in">
    <div class="container">
        <span class="eyebrow">@L["ctab.eyebrow"]</span>
        <h2>@L["ctab.title"]</h2>
        <p>@L["ctab.desc"]</p>
        <a class="btn btn-primary" href="javascript:void(0)" data-open-trial>@L["ctab.cta"]</a>
    </div>
</section>
