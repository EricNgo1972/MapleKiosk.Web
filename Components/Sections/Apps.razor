@inject LocalizationService L
@inject FamilyAppCatalog Catalog

<section class="section section--surface fade-in" id="apps">
    <div class="container">
        <div class="features__head">
            <div>
                <span class="eyebrow">@L["apps.eyebrow"]</span>
                <h2>@L["apps.title"]</h2>
            </div>
            <p>@L["apps.desc"]</p>
        </div>
        <div class="features__grid">
            @foreach (var app in _apps)
            {
                var href = app.PageSlug is null ? null : Localized(app.PageSlug);
                var cls = "feature" + (app.IsFeatured ? " feature--featured" : "") + (href is not null ? " feature--link" : "");
                @if (href is not null)
                {
                    <a class="@cls" href="@href">@CardBody(app)</a>
                }
                else
                {
                    <div class="@cls">@CardBody(app)</div>
                }
            }
        </div>
    </div>
</section>

@code {
    private IReadOnlyList<FamilyApp> _apps = Array.Empty<FamilyApp>();

    protected override async Task OnInitializedAsync()
    {
        _apps = await Catalog.GetAppsAsync();
    }

    // Locale-aware link to the product's page (/coffee -> /fr/coffee, ...).
    private string Localized(string path) => L.Culture == "en" ? path : $"/{L.Culture}{path}";

    private RenderFragment CardBody(FamilyApp app) => __builder =>
    {
        <text>
            @if (app.IsFeatured)
            {
                <span class="feature__flag">@L["apps.featured"]</span>
            }
            <span class="feature__num">@app.Number</span>
            <div class="feature__icon">@app.Icon</div>
            <h3>@app.Title</h3>
            @if (!string.IsNullOrEmpty(app.IndustryKey))
            {
                <span class="feature__ind">@L[app.IndustryKey]</span>
            }
            <p>@app.Description</p>
            @if (app.PageSlug is not null)
            {
                <span class="feature__more">@L["apps.explore"] <span aria-hidden="true">→</span></span>
            }
        </text>
    };
}
