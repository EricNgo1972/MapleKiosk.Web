@inject LocalizationService L

<section class="hero" id="top">
    <div class="container hero__grid">
        <div>
            <span class="eyebrow">@L["hero.eyebrow"]</span>
            <h1 class="hero__title">@L["hero.title.a"] <span>@L["hero.title.b"]</span></h1>
            <p class="hero__sub">@L["hero.sub"]</p>
            <div class="hero__ctas">
                <a class="btn btn-primary" href="javascript:void(0)" data-open-trial>@L["hero.cta1"]</a>
                <a class="btn btn-ghost" href="#apps">@L["hero.cta2"]</a>
            </div>
        </div>
        <div class="hero__image">
            <img src="https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=800&q=80"
                 alt="" loading="lazy" data-fallback="Hero image" />
            <img class="hero__circle" src="MapleKiosk_circle.svg" alt="" aria-hidden="true" />
        </div>
    </div>
</section>
