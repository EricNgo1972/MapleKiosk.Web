@inject LocalizationService L
@inject FamilyAppCatalog Catalog

<section class="section fade-in" id="pricing">
    <div class="container">
        <div class="pricing__intro">
            <span class="eyebrow">@L["price.eyebrow"]</span>
            <h2>@L["price.title"]</h2>
            <p>@L["price.sub"]</p>
        </div>

        <div class="price-table-wrap">
            <table class="price-table">
                <thead>
                    <tr>
                        <th>@L["price.col.app"]</th>
                        <th>@L["price.col.saas"]<span>@L["price.col.saas.note"]</span></th>
                        <th>@L["price.col.onprem"]<span>@L["price.col.onprem.note"]</span></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var app in _apps)
                    {
                        <tr class="@(app.IsFeatured ? "is-featured" : "")">
                            <td class="price-table__app">
                                <span class="price-table__icon">@app.Icon</span>
                                <span class="price-table__name">
                                    @app.Title
                                    @if (app.IsFeatured)
                                    {
                                        <em class="price-table__flag">@L["apps.featured"]</em>
                                    }
                                </span>
                            </td>
                            <td>
                                @if (app.SaasMonthlyUsd is decimal saas)
                                {
                                    <span class="price-table__price">$@saas.ToString("0.##")<small>@L["price.per.mo"]</small></span>
                                }
                                else
                                {
                                    <span class="price-table__custom">@L["price.custom"]</span>
                                }
                            </td>
                            <td>
                                @if (app.OnPremiseUsd is decimal onprem)
                                {
                                    <span class="price-table__price">$@onprem.ToString("0.##")<small>@L["price.per.once"]</small></span>
                                }
                                else
                                {
                                    <a class="price-table__call" href="javascript:void(0)" data-open-trial>@L["price.call"]</a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <p class="price-table__fine">@L["price.fine"]</p>

        <div class="pricing__cta">
            <a class="btn btn-primary" href="javascript:void(0)" data-open-trial>@L["price.cta.trial"]</a>
            <a class="btn btn-ghost" href="javascript:void(0)" data-open-trial>@L["price.cta.sales"]</a>
        </div>
    </div>
</section>

@code {
    private IReadOnlyList<FamilyApp> _apps = Array.Empty<FamilyApp>();

    protected override async Task OnInitializedAsync()
    {
        _apps = await Catalog.GetAppsAsync();
    }
}
